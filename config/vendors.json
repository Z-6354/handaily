{
  "version": 1,
  "defaults": {
    "text_vendor_id": "ollama",
    "vision_vendor_id": "ollama"
  },
  "removed_vendor_ids": ["volcano_ark", "volcano_coding"],
  "vendors": [
    {
      "id": "ollama",
      "name": "Ollama（本地）",
      "base_url": "http://127.0.0.1:11434",
      "adapter": "ollama",
      "requires_api_key": false
    },
    {
      "id": "volcano",
      "name": "火山引擎 Agent Plan",
      "base_url": "https://ark.cn-beijing.volces.com/api/plan/v3",
      "adapter": "openai",
      "requires_api_key": true,
      "test": {
        "strategy": "openai_or_ping",
        "ping_url": "https://ark.cn-beijing.volces.com/ping",
        "plan_label": "Agent Plan"
      },
      "hints": {
        "empty_models": "Agent Plan 未返回模型列表，请使用「手动添加」填写模型 ID（如 ark-code-latest）",
        "auth_error": "Agent Plan 请在方舟控制台「Agent Plan」创建专用 API Key，Base URL 使用 https://ark.cn-beijing.volces.com/api/plan/v3"
      },
      "default_models": {
        "text": "ark-code-latest",
        "vision": "doubao-seedream-5.0-lite"
      },
      "excluded_models": ["doubao-seed-code"]
    },
    {
      "id": "opencode",
      "name": "OpenCode GO 套餐",
      "base_url": "https://opencode.ai/zen/go/v1",
      "adapter": "openai",
      "requires_api_key": true,
      "hints": {
        "empty_models": "请使用「手动添加」填写模型 ID（如 deepseek-v4-pro、kimi-k2.7-code）",
        "auth_error": "OpenCode GO 请在 opencode.ai 订阅 Go 套餐并获取 API Key，Base URL 为 https://opencode.ai/zen/go/v1（不是 api.opencode.ai）"
      },
      "default_models": {
        "text": "deepseek-v4-pro",
        "thinking": "deepseek-v4-pro"
      }
    },
    {
      "id": "deepseek",
      "name": "DeepSeek API",
      "base_url": "https://api.deepseek.com",
      "adapter": "openai",
      "requires_api_key": true
    },
    {
      "id": "glm",
      "name": "GLM Coding 套餐",
      "base_url": "https://open.bigmodel.cn/api/paas/v4",
      "adapter": "openai",
      "requires_api_key": true
    },
    {
      "id": "agens",
      "name": "Agnes AI",
      "base_url": "https://apihub.agnes-ai.com/v1",
      "adapter": "openai",
      "requires_api_key": true
    }
  ]
}
