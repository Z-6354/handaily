{
  "name": "xiaohan-daily",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:fe": "vite build",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dev:tauri": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tauri-dev.ps1",
    "tauri:dev": "tauri dev --config src-tauri/tauri.preview.conf.json",
    "tauri:build": "tauri build",
    "tauri:build:exe": "tauri build --no-bundle",
    "tauri:pack": "tauri build --debug",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "check:css": "python tools/check-css-classes.py && python tools/check-pet-css.py",
    "test:pet-layout": "node tools/pet-layout-check.mjs",
    "test:pet-api": "node scripts/pet-test-api.mjs",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "blhx:import": "cargo run --manifest-path src-tauri/Cargo.toml --bin blhx_import --",
    "live2d:import": "cargo run --manifest-path src-tauri/Cargo.toml --bin live2d_import --",
    "avatar:import": "cargo run --manifest-path src-tauri/Cargo.toml --bin avatar_import --",
    "roster:check": "cargo run --manifest-path src-tauri/Cargo.toml --bin roster_check",
    "clean": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-project.ps1",
    "clean:debug": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-project.ps1 -Debug",
    "clean:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-project.ps1 -All",
    "tauri:build:debug": "tauri build --debug --no-bundle"
  },
  "dependencies": {
    "@pixi-spine/all-3.8": "^4.0.6",
    "@pixi-spine/runtime-3.8": "^4.0.6",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "pinyin-pro": "^3.28.1",
    "pixi.js": "^7.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  }
}
