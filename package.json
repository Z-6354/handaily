{
  "name": "xiaohan-daily",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:fe": "vite build",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dev:tauri": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tauri-dev.ps1",
    "tauri:dev": "tauri dev --config src-tauri/tauri.preview.conf.json",
    "tauri:build": "tauri build -- --bin xiaohan-daily",
    "tauri:release": "tauri build -- --bin xiaohan-daily && node scripts/copy-release.mjs",
    "build:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build.ps1",
    "tauri:build:exe": "tauri build --no-bundle -- --bin xiaohan-daily",
    "tauri:pack": "tauri build --debug",
    "check:rust": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 check --manifest-path src-tauri/Cargo.toml --lib",
    "check:rust:bin": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 check --manifest-path src-tauri/Cargo.toml --lib --bin xiaohan-daily",
    "check:rust:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 check --manifest-path src-tauri/Cargo.toml",
    "check:css": "python scripts/check-css-classes.py && python scripts/check-pet-css.py",
    "test:pet-layout": "node scripts/pet-layout-check.mjs",
    "test:pet-api": "node scripts/pet-test-api.mjs",
    "test:rust": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 test --manifest-path src-tauri/Cargo.toml --lib",
    "test:rust:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 test --manifest-path src-tauri/Cargo.toml",
    "blhx:import": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 run --manifest-path src-tauri/Cargo.toml --features cli-tools --bin blhx_import",
    "live2d:import": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 run --manifest-path src-tauri/Cargo.toml --features cli-tools --bin live2d_import",
    "avatar:import": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 run --manifest-path src-tauri/Cargo.toml --features cli-tools --bin avatar_import",
    "roster:export": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 run --release --manifest-path src-tauri/Cargo.toml --features cli-tools --bin roster_pack export",
    "icons:generate": "python scripts/generate-pet-icons.py",
    "clean": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-project.ps1",
    "clean:debug": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-project.ps1 -Debug",
    "clean:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-project.ps1 -All",
    "tauri:build:debug": "tauri build --debug --no-bundle"
  },
  "dependencies": {
    "@pixi-spine/all-3.8": "^4.0.6",
    "@pixi-spine/runtime-3.8": "^4.0.6",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "pinyin-pro": "^3.28.1",
    "pixi.js": "^7.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  }
}
