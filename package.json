{
  "name": "handaily",
  "version": "0.2.0",
  "private": true,
  "description": "HANDAILY monorepo — hanpet + hanimport + hantransfer + data",
  "workspaces": [
    "hanpet",
    "packages/*",
    "mcp/*"
  ],
  "scripts": {
    "start:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "stop:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "restart:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restart-dev.ps1",
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start.ps1",
    "hanagent": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/hanagent.ps1",
    "dev": "npm run dev -w hanpet",
    "build:fe": "npm run build:fe -w hanpet",
    "build": "npm run build -w hanpet",
    "tauri": "npm run tauri -w hanpet",
    "tauri:dev": "npm run tauri:dev -w hanpet",
    "tauri:build": "npm run tauri:build -w hanpet",
    "tauri:build:exe": "npm run tauri:build:exe -w hanpet",
    "build:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build.ps1",
    "check:rust": "npm run check:rust -w hanpet",
    "check:rust:bin": "npm run check:rust:bin -w hanpet",
    "check:rust:all": "npm run check:rust:all -w hanpet",
    "check:hanimport": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 check -p hanimport",
    "check:hantransfer": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 check -p hantransfer-desktop",
    "check:all": "npm run check:rust && npm run check:hanimport && npm run check:hantransfer && npm run build:fe",
    "check:encoding": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-encoding.ps1",
    "check:css": "npm run check:css -w hanpet",
    "start:hantransfer": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-hantransfer.ps1",
    "hantransfer": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 run -p hantransfer-desktop --",
    "hantransfer:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 build -p hantransfer-desktop",
    "hantransfer:apk": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-hantransfer-apk.ps1",
    "test:hantransfer": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 test -p hantransfer-desktop",
    "test:pet-layout": "npm run test:pet-layout -w hanpet",
    "test:pet-api": "npm run test:pet-api -w hanpet",
    "test:rust": "npm run test:rust -w hanpet",
    "test:rust:all": "npm run test:rust:all -w hanpet",
    "test:hanimport": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 test -p hanimport",
    "blhx:import": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 run -p xiaohan-daily --features cli-tools --bin blhx_import",
    "live2d:import": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 run -p xiaohan-daily --features cli-tools --bin live2d_import",
    "avatar:import": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 run -p xiaohan-daily --features cli-tools --bin avatar_import",
    "roster:export": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 run --release -p xiaohan-daily --features cli-tools --bin roster_pack export",
    "icons:generate": "npm run icons:generate -w hanpet",
    "hanimport": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 run -p hanimport --",
    "hanimport:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 build -p hanimport",
    "hanimport:serve": "python hanimport/scripts/serve_web.py",
    "hanimport:test": "python -m pytest hanimport/tests -q",
    "hanimport:config": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 run -p hanimport -- config",
    "hanimport:config:cubism": "python hanimport/scripts/build_cubism_config.py --input data/model/unpacked --force",
    "hanimport:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-hanimport-release.ps1",
    "live2d:plan": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cargo-dev.ps1 run -p hanimport -- plan",
    "migrate:live2d": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/migrate-live2d.ps1",
    "clean": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-project.ps1",
    "clean:whatif": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-project.ps1 -WhatIf -Report",
    "clean:debug": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-project.ps1 -Debug",
    "clean:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-project.ps1 -All",
    "clean:hantransfer": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-hantransfer.ps1",
    "clean:stale-target": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-stale-target.ps1",
    "hanimport:motions": "python hanimport/scripts/merge_live2d_motions.py",
    "hanimport:wiki-enrich": "python hanimport/scripts/wiki_enrich_characters.py",
    "roster:init": "python hanimport/scripts/roster_db.py init",
    "roster:import": "python hanimport/scripts/roster_db.py import-bundled-seed && python hanimport/scripts/roster_db.py import-wiki",
    "roster:sync": "python hanimport/scripts/roster_db.py sync-appdata",
    "roster:publish": "python hanimport/scripts/roster_db.py publish-bundled",
    "roster:verify": "python hanimport/scripts/roster_db.py verify",
    "roster:repair-l2d": "python hanimport/scripts/roster_db.py repair-l2d-binds",
    "roster:merge-dups": "python hanimport/scripts/merge_duplicate_characters.py",
    "roster:pack-slot": "python hanimport/scripts/roster_skin_slot_pack.py"
  }
}
